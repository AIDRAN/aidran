{
  "name": "@aidran/contracts",
  "version": "0.5.0",
  "description": "AIDRAN — shared TypeScript types and Zod schemas for inter-service events, API DTOs, webhooks, and tier policies",
  "keywords": [
    "aidran",
    "discourse-intelligence",
    "contracts",
    "zod",
    "typescript",
    "types"
  ],
  "homepage": "https://github.com/AIDRAN/aidran#readme",
  "bugs": {
    "url": "https://github.com/AIDRAN/aidran/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIDRAN/aidran.git",
    "directory": "packages/contracts"
  },
  "license": "Apache-2.0",
  "author": "AIDRAN contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./tiers": {
      "types": "./dist/tiers.d.ts",
      "import": "./dist/tiers.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepare": "tsc"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
