{
  "name": "@aidran/db",
  "version": "0.5.0",
  "description": "AIDRAN — Drizzle ORM schemas plus generated SQL migrations for the corpus tables (records, analysis, signals, editorial, search-sync). Public reference; production system uses additional tables not included here.",
  "keywords": [
    "aidran",
    "discourse-intelligence",
    "drizzle",
    "postgres",
    "schema",
    "typescript"
  ],
  "homepage": "https://github.com/AIDRAN/aidran#readme",
  "bugs": {
    "url": "https://github.com/AIDRAN/aidran/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIDRAN/aidran.git",
    "directory": "packages/db"
  },
  "license": "Apache-2.0",
  "author": "AIDRAN contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./migrations-path": {
      "types": "./dist/migrations-path.d.ts",
      "import": "./dist/migrations-path.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepare": "tsc",
    "generate": "tsc && drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
