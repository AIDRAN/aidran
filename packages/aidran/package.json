{
  "name": "aidran",
  "version": "0.5.0",
  "description": "AIDRAN — one install for the discourse-intelligence platform. Re-exports @aidran/contracts and @aidran/db, plus the @aidran/cli binary as `aidran`.",
  "keywords": [
    "aidran",
    "discourse-intelligence",
    "platform",
    "postgres",
    "drizzle",
    "zod"
  ],
  "homepage": "https://github.com/AIDRAN/aidran#readme",
  "bugs": {
    "url": "https://github.com/AIDRAN/aidran/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIDRAN/aidran.git",
    "directory": "packages/aidran"
  },
  "license": "Apache-2.0",
  "author": "AIDRAN contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./db/migrations-path": {
      "types": "./dist/db-migrations-path.d.ts",
      "import": "./dist/db-migrations-path.js"
    }
  },
  "bin": {
    "aidran": "./bin/aidran.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && chmod +x bin/aidran.js",
    "prepare": "tsc && chmod +x bin/aidran.js"
  },
  "dependencies": {
    "@aidran/cli": "workspace:*",
    "@aidran/contracts": "workspace:*",
    "@aidran/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
